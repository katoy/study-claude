APP_NAME=お問い合わせフォーム
APP_ENV=local
# 暗号鍵は共有しません。コピー後に composer setup または php artisan key:generate で生成します。
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# 日時は UTC で保存し、画面では日本時間として表示します。
APP_TIMEZONE=UTC
APP_DISPLAY_TIMEZONE=Asia/Tokyo
APP_LOCALE=ja
APP_FALLBACK_LOCALE=ja
APP_FAKER_LOCALE=ja_JP

# ローカル開発専用の公開済み認証情報です。AdminUserSeeder を編集なしで実行できます。
# 本番環境では必ず独自のメールアドレスと12文字以上のランダムなパスワードへ変更してください。
ADMIN_NAME=ローカル管理者
ADMIN_EMAIL=admin@example.test
ADMIN_PASSWORD=local-only-not-a-secret

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
# ローカルの HTTP 接続では false。本番の HTTPS 環境では true にしてください。
SESSION_SECURE_COOKIE=false
# 本番では strict を推奨します。外部サイトからの遷移要件がある場合は lax を検討してください。
SESSION_SAME_SITE=lax
SESSION_PATH=/
SESSION_DOMAIN=null

# 1分間・送信元 IP ごとの上限です。確認画面と登録処理を別々に制限します。
CONTACT_CONFIRMATION_RATE_LIMIT=30
CONTACT_SUBMISSION_RATE_LIMIT=5

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.test"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
