{
  "name": "todo-app2",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check \"src/**/*.js\" \"tests/**/*.js\"",
    "format:fix": "prettier --write \"src/**/*.js\" \"tests/**/*.js\""
  },
  "dependencies": {
    "dompurify": "^3.0.9",
    "quill": "^2.0.0-rc.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.8.0",
    "@testing-library/dom": "^9.3.4",
    "@vitest/coverage-v8": "^1.3.1",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-no-unsanitized": "^4.0.2",
    "globals": "^15.0.0",
    "jsdom": "^24.0.0",
    "prettier": "^3.2.5",
    "vite": "^5.1.4",
    "vite-plugin-singlefile": "^2.0.1",
    "vitest": "^1.3.1"
  }
}
